# Nova Testimonial Backend Environment Variables

# Database Configuration
DATABASE_URI=mongodb+srv://username:password@cluster.mongodb.net/nova-testimonial

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Email Configuration (Gmail)
EMAIL_SERVICE=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration (Update after frontend deployment)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Optional: Twilio Configuration (if using SMS)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token