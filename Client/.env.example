# Nova Testimonial Frontend Environment Variables

# API Base URL - Update this after backend deployment
VITE_API_BASE_URL=http://localhost:3000

# App Configuration
VITE_APP_NAME=Kiki Testimonial
VITE_APP_VERSION=1.0.0

# For production, update VITE_API_BASE_URL to your Railway backend URL:
# VITE_API_BASE_URL=https://your-app-name.railway.app